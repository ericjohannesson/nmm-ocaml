</cr_id>
<cs_blks>
<cu_blk_txt>
<cs_blk_txt>
<cs_txt_units>
<cu_txt_unit_wysiwyg>
<cs_txt_unit_wysiwyg>‘REFERENCES(1)’ (or something similar), or</cs_txt_unit_wysiwyg>
</cu_txt_unit_wysiwyg>
</cs_txt_units>
</cs_blk_txt>
</cu_blk_txt>
</cs_blks>
</cr_blk_itm>
