<cu_txt_unit_wysiwyg>
<cs_txt_unit_wysiwyg>my preferred solution: ‘[1]’, with item labels under REFERENCES rendered as ‘[1]’, ‘[2]’, etc.</cs_txt_unit_wysiwyg>
</cu_txt_unit_wysiwyg>
</cs_txt_units>
</cs_blk_txt>
</cu_blk_txt>
